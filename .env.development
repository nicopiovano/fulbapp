# Simula "hoy" para desarrollo (partidos de marzo 2025 se ven como futuros)
VITE_OVERRIDE_DATE=2025-03-06

# API base:
# - Para usar backend local de Laravel con proxy de Vite: /api (default)
# - Para apuntar directo al backend remoto: https://fulbapp-api-production.up.railway.app/api
# VITE_API_BASE_URL=https://fulbapp-api-production.up.railway.app/api
VITE_API_BASE_URL=/api

# Modo mock: true = datos en memoria (sin backend), false = API REST real
VITE_USE_MOCK=false
